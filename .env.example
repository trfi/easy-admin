# --- BFF ---
# Shared production Mongo — read-only (all writes proxy to EasyQuiz / Hepi)
MONGODB_URI=mongodb://localhost:27017/easyquiz

# Auth: dashboard issues its own JWT from an env credential
JWT_SECRET=change-me-long-random-string
ADMIN_USERNAME=admin
# Plain-text admin password (single-operator tool; stored as-is in the env)
ADMIN_PASSWORD=change-me

# Cross-repo points-adjust call to EasyQuiz api
EASY_API_URL=https://api.easyquiz.cc

# Cross-repo AI-config admin calls to Hepi (/ai-models). Hepi owns the AI provider
# + model-combo collections and serves them from a 60s runtime cache, so all AI
# writes/tests proxy here (X-Admin-Secret) instead of writing Mongo directly.
HEPI_API_URL=https://api.hepi.cc
HEPI_ADMIN_SECRET=shared-admin-secret-between-bff-and-hepi

# Revenue: unified-VND conversion rate ($1 = N VND), adjustable without code change
USD_TO_VND_RATE=26309

# Server
PORT=3010
